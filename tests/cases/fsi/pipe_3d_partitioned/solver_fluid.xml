<?xml version="1.0" encoding="UTF-8" ?>
<svMultiPhysicsFile version="0.1">

<!-- Fluid + mesh (ALE) solve on lumen mesh for partitioned FSI.
     The mesh equation provides DOFs 4-6 for ALE mesh velocity in the
     fluid assembly (construct_fluid subtracts mesh velocity from convective
     velocity when mvMsh=true). Both equations share the same solution arrays.
     The coupling code solves mesh (eq 1) then fluid (eq 0) in each iteration. -->

<GeneralSimulationParameters>
  <Continue_previous_simulation> 0 </Continue_previous_simulation>
  <Number_of_spatial_dimensions> 3 </Number_of_spatial_dimensions>
  <Number_of_time_steps> 50 </Number_of_time_steps>
  <Time_step_size> 1e-4 </Time_step_size>
  <Spectral_radius_of_infinite_time_step> 0.50 </Spectral_radius_of_infinite_time_step>
  <Save_results_to_VTK_format> true </Save_results_to_VTK_format>
  <Name_prefix_of_saved_VTK_files> result_fluid </Name_prefix_of_saved_VTK_files>
  <Increment_in_saving_VTK_files> 1 </Increment_in_saving_VTK_files>
  <Start_saving_after_time_step> 1 </Start_saving_after_time_step>
  <Increment_in_saving_restart_files> 50 </Increment_in_saving_restart_files>
  <Verbose> 1 </Verbose>
  <Warning> 0 </Warning>
  <Debug> 0 </Debug>
</GeneralSimulationParameters>

<Add_mesh name="lumen" >
  <Mesh_file_path> mesh/fluid/mesh-complete.mesh.vtu </Mesh_file_path>
  <Add_face name="lumen_inlet">
      <Face_file_path> mesh/fluid/mesh-surfaces/start.vtp </Face_file_path>
  </Add_face>
  <Add_face name="lumen_outlet">
      <Face_file_path> mesh/fluid/mesh-surfaces/end.vtp </Face_file_path>
  </Add_face>
  <Add_face name="lumen_wall">
      <Face_file_path> mesh/fluid/mesh-surfaces/interface.vtp </Face_file_path>
  </Add_face>
  <Domain> 0 </Domain>
</Add_mesh>

<!-- Minimal Partitioned_coupling to set mvMsh flag for mesh equation -->
<Partitioned_coupling>
  <Fluid_interface_face> lumen_wall </Fluid_interface_face>
  <Solid_interface_face> lumen_wall </Solid_interface_face>
</Partitioned_coupling>

<Add_equation type="fluid" >
   <Coupled> false </Coupled>
   <Min_iterations> 1 </Min_iterations>
   <Max_iterations> 10 </Max_iterations>
   <Tolerance> 1e-8 </Tolerance>

   <Domain id="0" >
      <Equation> fluid </Equation>
      <Density> 1.0 </Density>
      <Viscosity model="Constant" >
         <Value> 0.04 </Value>
      </Viscosity>
      <Backflow_stabilization_coefficient> 0.2 </Backflow_stabilization_coefficient>
   </Domain>

   <LS type="GMRES" >
      <Linear_algebra type="fsils" >
         <Preconditioner> fsils </Preconditioner>
      </Linear_algebra>
      <Tolerance> 1e-14 </Tolerance>
      <Max_iterations> 200 </Max_iterations>
      <Krylov_space_dimension> 100 </Krylov_space_dimension>
   </LS>

   <Output type="Spatial" >
     <Velocity> true </Velocity>
     <Pressure> true </Pressure>
   </Output>

   <Add_BC name="lumen_inlet" >
      <Type> Neu </Type>
      <Value> 5.0e4 </Value>
   </Add_BC>

   <Add_BC name="lumen_wall" >
      <Type> Dir </Type>
      <Value> 0.0 </Value>
   </Add_BC>

</Add_equation>

<!-- Mesh equation (ALE): solved before fluid in the coupling loop.
     Provides mesh displacement (DOFs 4-6) and mesh velocity for ALE. -->
<Add_equation type="mesh" >
   <Coupled> false </Coupled>
   <Min_iterations> 1 </Min_iterations>
   <Max_iterations> 10 </Max_iterations>
   <Tolerance> 1e-6 </Tolerance>
   <Poisson_ratio> 0.3 </Poisson_ratio>

   <Domain id="0" >
      <Equation> mesh </Equation>
      <Density> 0.0 </Density>
      <Elasticity_modulus> 1.0 </Elasticity_modulus>
      <Poisson_ratio> 0.3 </Poisson_ratio>
   </Domain>

   <LS type="CG" >
      <Linear_algebra type="fsils" >
         <Preconditioner> fsils </Preconditioner>
      </Linear_algebra>
      <Tolerance> 1e-12 </Tolerance>
      <Max_iterations> 400 </Max_iterations>
   </LS>

   <Output type="Spatial" >
     <Displacement> true </Displacement>
   </Output>

   <Add_BC name="lumen_inlet" >
      <Type> Dir </Type>
      <Value> 0.0 </Value>
   </Add_BC>

   <Add_BC name="lumen_outlet" >
      <Type> Dir </Type>
      <Value> 0.0 </Value>
   </Add_BC>

   <!-- No BC on lumen_wall for the mesh equation. The wall displacement
        is prescribed by the coupling code (apply_displacement_on_mesh)
        and enforced via enforce_dirichlet_on_face in the post-assembly
        callback. This matches the monolithic solver where the wall
        displacement comes from the FSI equation DOFs, not a mesh BC. -->

</Add_equation>

</svMultiPhysicsFile>
